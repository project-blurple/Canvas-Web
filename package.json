{
  "name": "blurple-canvas-web",
  "displayName": "Blurple Canvas Web",
  "description": "Monorepo for the web app for the pixel-placing Blurple Canvas event.",
  "private": true,
  "contributors": [
    "Aaron Guo <aaronjoshguo@gmail.com>",
    "Emily Zou <yzou415@aucklanduni.ac.nz>",
    "Henry Wang <hwan513@aucklanduni.ac.nz> (http://henryh.wang)",
    "Jasper Lai <klai866@aucklanduni.ac.nz> (https://lai.nz)",
    "Josh Jeffers <joshjeffers600@gmail.com> (https://pumbas.net)",
    "Samuel Ou <me@sjou.dev> (https://sjou.dev)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/project-blurple/Canvas-Web.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/project-blurple/Canvas-Web/issues"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "dev": "pnpm --recursive --parallel dev",
    "start": "pnpm --recursive --parallel start",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "format": "pnpm --recursive format",
    "format:fix": "pnpm --recursive format:fix",
    "check": "pnpm --recursive check",
    "check:fix": "pnpm --recursive check:fix",
    "prepare": "husky",
    "clean": "pnpm --recursive clean && rm -rf node_modules/",
    "prisma:push": "pnpm --filter=backend prisma:push",
    "prisma:seed": "pnpm --filter=backend prisma:seed --",
    "prisma:migrate": "pnpm --filter=backend prisma:migrate"
  },
  "lint-staged": {
    "*.{css,html,md,markdown,yaml,yml}": "pnpm exec prettier --write",
    "*.{cjs,d.cts,d.mts,js,json,jsonc,jsx,mjs,ts,tsx}": [
      "pnpm exec prettier --write",
      "pnpm exec biome check --write --formatter-enabled=false --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=25",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.12.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
