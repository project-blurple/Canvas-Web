{
  "$schema": "https://unpkg.com/knip@6/schema.json",

  "tags": ["-lintignore"],
  "workspaces": {
    "packages/backend": {
      "project": ["src/**/*.ts!"],
      "ignore": ["src/client/generated/**"]
    },
    "packages/frontend": {
      "project": ["src/**/*.ts!", "src/**/*.tsx!"]
    },
    "packages/types": {
      "project": ["src/**/*.ts"]
    }
  }
}
